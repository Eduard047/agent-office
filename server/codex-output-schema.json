{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "tasks", "final_answer"],
  "properties": {
    "summary": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "minItems": 3,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "result"],
        "properties": {
          "title": {
            "type": "string"
          },
          "result": {
            "type": "string"
          }
        }
      }
    },
    "final_answer": {
      "type": "string"
    }
  }
}
